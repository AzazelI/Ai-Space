# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# AI Model API Keys
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Local Workspace Configuration
WORKSPACE_DIR=C:\Users\User\Desktop\AftersaleBrainstorm\Aftesale
DEFAULT_MODE=collaborative

# --- Security (REQUIRED) ---
# Your numeric Telegram user ID(s), comma-separated. Get yours from @userinfobot.
# Only these IDs can command the bot. Without this, /build is refused for everyone.
ALLOWED_TELEGRAM_USER_IDS=

# --- Autonomous "do real work from your phone" mode ---
# Turn on /build, which drives the local `claude` CLI to edit code & run commands.
ENABLE_AUTONOMOUS=false
# Permission mode for headless claude: acceptEdits (auto-accept edits) or
# bypassPermissions (skip ALL prompts — most autonomous, highest risk).
CLAUDE_PERMISSION_MODE=acceptEdits
# Path to the claude CLI (leave as "claude" if it's on your PATH).
CLAUDE_CLI_PATH=claude
# Auto commit + push after a successful /build task.
AUTO_PUSH=false
# Max seconds a single autonomous task may run before being killed.
AUTONOMOUS_TIMEOUT=600

# Route the "Claude" voice in /claude /ask /debate through the local claude CLI
# (your Claude Pro subscription) instead of the Anthropic API. true = no API key
# and no paid credits needed. The CLI is run with ANTHROPIC_API_KEY stripped so
# it uses your Pro login, not API billing.
CLAUDE_DISCUSSION_VIA_CLI=true
