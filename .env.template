# Council Room — copy to .env and fill in. .env is gitignored.

# --- Gemini (Antigravity's voice) — REQUIRED ---
# A single key is fine. For rotation on 429s, set GEMINI_API_KEYS=key1,key2
GEMINI_API_KEY=your_gemini_api_key_here

# --- Build workspace: where the loop edits the project under construction ---
# Leave blank to default to ./workspace inside this repo.
WORKSPACE_DIR=

# --- Claude worker (local `claude` CLI on your Pro login — no API key/credits) ---
CLAUDE_CLI_PATH=claude
# acceptEdits (auto-accept file edits) or bypassPermissions (skip ALL prompts — highest risk)
CLAUDE_PERMISSION_MODE=acceptEdits
# Hard ceiling (seconds) for a single build task before it is killed.
AUTONOMOUS_TIMEOUT=600
# Auto commit + push after the build loop's reviewer APPROVES.
# false = you push the finished project on purpose, not automatically.
AUTO_PUSH=false

# --- Budget guards ---
# MAX_TASK_COST_USD: per build-task ceiling (0 = off). DAILY_TOKEN_BUDGET: daily cap (0 = off).
MAX_TASK_COST_USD=2.0
DAILY_TOKEN_BUDGET=2000000
